{
  "name": "@agent-runtime/channel-h5",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "src/ui/dist"],
  "scripts": {
    "build:ui": "vite build --config src/ui/vite.config.ts",
    "build:server": "tsc -p tsconfig.json",
    "build": "pnpm build:ui && pnpm build:server",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@fastify/static": "^8.0.4",
    "fastify": "^5.8.5",
    "undici": "^7.0.0"
  },
  "devDependencies": {
    "@aily-ui/chat-bubble": "github:yarnovo/aily-ui-chat-bubble",
    "@aily-ui/chat-input": "github:yarnovo/aily-ui-chat-input",
    "@aily-ui/chat-layout": "github:yarnovo/aily-ui-chat-layout",
    "@aily-ui/tokens": "github:yarnovo/aily-ui-tokens",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "vite": "^6.0.5"
  }
}
