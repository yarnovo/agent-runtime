# 阿里云 DashScope OpenAI-compatible API key
# 申请: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=sk-xxx

# 模型 id (默认 qwen-max · 也可换 qwen-plus / qwen-turbo)
DASHSCOPE_MODEL=qwen-max

# 服务端口 (默认 8080)
PORT=8080

# 启用 channel plug-in (逗号分隔 · 默认 h5)
# 可选: h5, feishu, wechat, wecom, dingtalk
# 例: CHANNEL_ENABLED=h5,feishu  → 同时挂 web UI + 飞书 webhook
CHANNEL_ENABLED=h5
